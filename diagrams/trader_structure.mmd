classDiagram
    class AppUI {
        <<app.py>>
        +render_dashboard()
        +get_user_inputs()
    }
    
    class MainOrchestrator {
        <<main.py>>
        +initialize_system()
        +run_prediction_pipeline(ticker)
    }
    
    class ConflictDetector {
        +validate_inputs(data) bool
        +detect_logical_contradictions()
    }
    
    class KalshiTrader {
        -String api_key_id
        -String private_key_path
        -ApiClient api_client
        -MarketsApi market_client
        -PortfolioApi portfolio_client
        +__init__(env_path)
        +connect()
        +get_balance() float
        +get_market_data(ticker) dict
        +place_order(ticker, side, price, quantity) bool
    }

    class TradeLogger {
        +String log_file
        +log_trade(trade_details)
        +log_error(error_message)
    }

    class EnvironmentLoader {
        +load_secrets(env_path) dict
    }
    
    class KalshiTestSandbox {
        <<kalshi_test.py>>
        +test_api_connection()
    }

    AppUI --> MainOrchestrator : Sends inputs / Requests data
    MainOrchestrator --> ConflictDetector : Validates logic pre-trade
    MainOrchestrator --> KalshiTrader : Executes core market functions
    KalshiTrader --> EnvironmentLoader : uses (Fetches credentials)
    KalshiTrader --> TradeLogger : uses (Records activity)
    KalshiTestSandbox ..> KalshiTrader : (Isolated testing only)